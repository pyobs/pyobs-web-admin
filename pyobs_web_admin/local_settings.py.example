# Local overrides — copy this file to local_settings.py and fill in the values.
# local_settings.py is not committed to version control.

# Generate with:
#   DJANGO_SETTINGS_MODULE=pyobs_web_admin.settings uv run python -c \
#     "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY = ""

DEBUG = False
ALLOWED_HOSTS = ["your-hostname-or-ip"]

# Enable once HTTPS is in place
# SESSION_COOKIE_SECURE = True
# CSRF_COOKIE_SECURE = True

# Path to the pyobs executable
PYOBS_EXEC = "/opt/pyobs/venv/bin/pyobs"

# pyobs directories
PYOBS_CONFIG_DIR = "/opt/pyobs/config"
PYOBS_LOG_DIR = "/opt/pyobs/log"
PYOBS_RUN_DIR = "/opt/pyobs/run"
PYOBS_LOG_LEVEL = "info"

# Generate the password hash with:
#   DJANGO_SETTINGS_MODULE=pyobs_web_admin.settings uv run python -c \
#     "from django.contrib.auth.hashers import make_password; print(make_password('yourpassword'))"
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD_HASH = ""
