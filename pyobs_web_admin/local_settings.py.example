# Local overrides — copy this file to local_settings.py and fill in the values.
# local_settings.py is not committed to version control.

# Generate with:
#   DJANGO_SETTINGS_MODULE=pyobs_web_admin.settings uv run python -c \
#     "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY = ""

DEBUG = False
ALLOWED_HOSTS = ["your-hostname-or-ip"]

# Enable once HTTPS is in place
# SESSION_COOKIE_SECURE = True
# CSRF_COOKIE_SECURE = True

# Path to the pyobs executable
PYOBS_EXEC = "/opt/pyobs/venv/bin/pyobs"

# pyobs directories
PYOBS_CONFIG_DIR = "/opt/pyobs/config"
PYOBS_LOG_DIR = "/opt/pyobs/log"
PYOBS_RUN_DIR = "/opt/pyobs/run"
PYOBS_LOG_LEVEL = "info"

# Where module logs live -- see DEV_JOURNALD_LOGS.md. None (default) auto-detects from
# pyobsd's own config file. Set explicitly to "file" or "journald" to override.
# PYOBS_LOG_BACKEND = None

# Packages page: what's installed (via `pip list`) is always the primary source of truth,
# this is only for what pip's own installed-environment metadata can't recover later --
# an extras spec (pip never remembers a package was installed with "[full]", so a later
# upgrade would silently drop it) and/or extra non-"pyobs"-prefixed packages to also show
# and manage from the same page. pyobs-core is installed with the "full" extra by default.
PYOBS_MANAGED_PACKAGES = ["pyobs-core[full]"]

# Generate the password hash with:
#   DJANGO_SETTINGS_MODULE=pyobs_web_admin.settings uv run python -c \
#     "from django.contrib.auth.hashers import make_password; print(make_password('yourpassword'))"
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD_HASH = ""

# Hub: allow this instance to be controlled by a hub (leave empty to disable)
HUB_TOKEN = ""

# Hub: remote hosts this instance can control
# Each entry must have: name (display label), url (base URL), token (shared secret)
# HUB_HOSTS = [
#     {"name": "obs1", "url": "http://obs1:8765", "token": "shared-secret"},
#     {"name": "obs2", "url": "http://obs2:8765", "token": "another-secret"},
# ]
HUB_HOSTS = []

# ejabberd integration -- see DEV_EJABBERD_INTEGRATION.md. Off by default: not every fleet
# has ejabberd co-located. Uncomment and adjust to enable.
# EJABBERD_ENABLED = True
# EJABBERD_HOST = "localhost"  # name of the HUB_HOSTS entry (or "localhost") running ejabberd
# EJABBERD_DOMAIN = "your-xmpp-domain"
# EJABBERD_API_URL = "http://127.0.0.1:5281/api"
# EJABBERDCTL = "ejabberdctl"
